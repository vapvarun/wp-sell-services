<?xml version="1.0"?>
<ruleset name="WP Sell Services Coding Standards">
    <description>WordPress Coding Standards for WP Sell Services plugin</description>

    <!-- What to scan -->
    <file>.</file>

    <!-- Exclude paths -->
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/assets/*</exclude-pattern>
    <exclude-pattern>/languages/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>
    <exclude-pattern>/plans/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>

    <!-- How to scan -->
    <arg value="sp"/> <!-- Show sniff and progress -->
    <arg name="basepath" value="."/> <!-- Strip the file paths down to the relevant bit -->
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/> <!-- Enables parallel processing when available for faster results -->

    <!-- Rules: Check PHP version compatibility -->
    <config name="testVersion" value="8.1-"/>
    <rule ref="PHPCompatibilityWP">
        <include-pattern>*\.php$</include-pattern>
    </rule>

    <!-- Rules: WordPress Coding Standards -->
    <config name="minimum_wp_version" value="6.4"/>

    <rule ref="WordPress">
        <!-- Allow short array syntax (PHP 5.4+, used throughout codebase) -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <!-- Allow PSR-4 file naming for classes (autoloading) -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <!-- Allow short ternary operators (PHP 7+, used throughout codebase) -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>
        <!-- Allow direct DB queries — plugin uses custom tables with repository pattern -->
        <exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
        <exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
        <!-- Allow interpolated table names in $wpdb->prepare() — all queries use prepare() -->
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
        <exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
        <!-- Allow non-Yoda conditions — project uses standard condition order -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
        <!-- Templates use standard variable names ($order, $service, etc.) -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>
        <!-- Template hooks use descriptive names -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedHooknameFound"/>
        <!-- Allow global variable overrides in templates ($type, $status, etc.) -->
        <exclude name="WordPress.WP.GlobalVariablesOverride.Prohibited"/>
        <!-- Allow inline comments without punctuation -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <!-- Skip translator comments for placeholders (handled during i18n review) -->
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
        <!-- Skip doc comment issues (handled separately) -->
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectTypeHint"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamNameNoMatch"/>
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <!-- Allow multiple classes in stub files -->
        <exclude name="Generic.Files.OneObjectStructurePerFile.MultipleFound"/>
    </rule>

    <!-- Verify that the text_domain is set to the desired text-domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wp-sell-services"/>
            </property>
        </properties>
    </rule>

    <!-- Allow namespaced hook names -->
    <rule ref="WordPress.NamingConventions.ValidHookName">
        <properties>
            <property name="additionalWordDelimiters" value="/"/>
        </properties>
    </rule>

    <!-- Verify that everything in the global namespace is prefixed -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wpss"/>
                <element value="wp_sell_services"/>
                <element value="WPSellServices"/>
            </property>
        </properties>
    </rule>

    <!-- Custom capabilities used by this plugin -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="wpss_manage_orders"/>
                <element value="wpss_manage_services"/>
                <element value="wpss_view_analytics"/>
                <element value="wpss_manage_disputes"/>
                <element value="wpss_manage_withdrawals"/>
            </property>
        </properties>
    </rule>
</ruleset>
